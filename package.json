{
  "name": "mrgwallet",
  "version": "0.1.0",
  "private": true,
  "description": "MRGWallet — official MergeOS MRG wallet for Android, Chrome, and Firefox",
  "type": "module",
  "scripts": {
    "test": "node --test",
    "demo": "node ./scripts/demo.mjs",
    "serve": "node ./scripts/serve.mjs",
    "build:web": "node ./scripts/build-web.mjs",
    "build:extensions": "node ./scripts/build-extensions.mjs",
    "sync:android": "node ./scripts/sync-android-assets.mjs",
    "validate:manifests": "node ./scripts/validate-extension-manifests.mjs",
    "build": "npm run build:web && npm run build:extensions && npm run sync:android",
    "package:release": "node ./scripts/package-release.mjs"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "keywords": [
    "mergeos",
    "mrg",
    "wallet",
    "solana",
    "chrome-extension",
    "firefox-extension",
    "android"
  ],
  "license": "MIT"
}
