{
  "manifest_version": 3,
  "name": "MRGWallet",
  "version": "0.1.0",
  "description": "MergeOS MRG wallet — balances, ledger tip, claim receipts",
  "browser_specific_settings": {
    "gecko": {
      "id": "mrgwallet@mergeos.shop",
      "strict_min_version": "109.0"
    }
  },
  "action": {
    "default_title": "MRGWallet",
    "default_popup": "web/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://mergeos.shop/*",
    "https://scan.mergeos.shop/*"
  ]
}
